# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=your_admin_password
JWT_SECRET=your_jwt_secret_key
PORT=3002

# Deployment URLs (for Railway)
# FRONTEND_URL=https://your-app-name.up.railway.app
# BACKEND_URL=https://your-app-name.up.railway.app
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3002

# Przelewy24 Configuration
P24_MERCHANT_ID=your_merchant_id
P24_POS_ID=your_pos_id
P24_CRC=your_crc_key
P24_API_KEY=your_api_key
P24_SANDBOX=true

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Railway PostgreSQL Database (automatically provided by Railway)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/digitalsite
